{
  "name": "rest-countries-zustand",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "a11y:ci": "kill-port 5173 && start-server-and-test dev http://localhost:5173 \"yarn pa11y-ci --config pa11yci.cjs\"",
    "lighthouse:ci": "lhci autorun",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:e2e": "start-server-and-test dev http://localhost:5173 cy:run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.99.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "cypress": "^15.14.1",
    "cypress-axe": "^1.7.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.0.2",
    "kill-port": "^2.0.1",
    "msw": "^2.13.4",
    "pa11y": "^9.1.1",
    "pa11y-ci": "^4.1.0",
    "sass": "^1.99.0",
    "start-server-and-test": "^3.0.2",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
